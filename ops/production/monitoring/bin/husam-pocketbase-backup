#!/usr/bin/env bash
set -euo pipefail

readonly backup_root="${BACKUP_ROOT:-/var/backups/husam/pocketbase}"
readonly retention_days="${BACKUP_RETENTION_DAYS:-14}"
readonly timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
readonly destination="${backup_root}/${timestamp}"
readonly pocketbase_data_root="${POCKETBASE_DATA_ROOT:-/opt/pocketbase/pb_data}"
readonly temporary_destination="${backup_root}/.${timestamp}.tmp.$$"
readonly pocketbase_service="${POCKETBASE_SERVICE:-pocketbase.service}"

pocketbase_was_active=false

restore_pocketbase() {
  if [[ "${pocketbase_was_active}" == "true" ]]; then
    systemctl start "${pocketbase_service}"
  fi
}

umask 077
install -d -m 700 "${backup_root}"
exec 9>"/run/lock/husam-pocketbase-backup.lock"
flock -n 9 || exit 0

install -d -m 700 "${temporary_destination}"
trap 'restore_pocketbase; rm -rf -- "${temporary_destination}"' EXIT

if systemctl is-active --quiet "${pocketbase_service}"; then
  systemctl stop "${pocketbase_service}"
  pocketbase_was_active=true
fi

# sqlite3 is not installed on the VPS. PocketBase is already quiesced above,
# and the Python sqlite backup API keeps the database copy consistent.
python3 - "${temporary_destination}" "${pocketbase_data_root}" <<'PY'
import sqlite3
import sys
from pathlib import Path

destination = Path(sys.argv[1])
data_root = Path(sys.argv[2])
for filename in ("data.db", "auxiliary.db"):
    source = sqlite3.connect(
        f"file:{data_root / filename}?mode=ro", uri=True
    )
    target = sqlite3.connect(destination / filename)
    try:
        source.backup(target)
    finally:
        target.close()
        source.close()
PY

tar --create --gzip --file "${temporary_destination}/storage.tar.gz" \
  --directory "${pocketbase_data_root}" storage

(cd "${temporary_destination}" && sha256sum data.db auxiliary.db storage.tar.gz > SHA256SUMS)

mv -- "${temporary_destination}" "${destination}"
find "${backup_root}" -mindepth 1 -maxdepth 1 -type d -mtime "+${retention_days}" -exec rm -rf {} +
